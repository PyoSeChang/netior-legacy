{
  "name": "@netior/desktop-app",
  "version": "1.3.2",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "prepare:node-runtime": "node scripts/prepare-node-runtime.js",
    "prepare:sidecars": "node scripts/prepare-sidecars.js",
    "rebuild:electron": "electron-rebuild -f -o node-pty",
    "postinstall": "electron-rebuild -f -o node-pty",
    "dev": "electron-vite dev",
    "dev:theme-lab": "vite src/renderer --host 127.0.0.1 --port 5177",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "pnpm --filter @netior/shared build && pnpm --filter @netior/core build && pnpm --filter @netior/service build && pnpm --filter @netior/mcp build && pnpm --filter @netior/narre-server build && pnpm run clean && pnpm run build && pnpm run prepare:node-runtime && pnpm run prepare:sidecars && electron-builder",
    "package:win": "pnpm --filter @netior/shared build && pnpm --filter @netior/core build && pnpm --filter @netior/service build && pnpm --filter @netior/mcp build && pnpm --filter @netior/narre-server build && pnpm run clean && pnpm run build && pnpm run prepare:node-runtime && pnpm run prepare:sidecars && electron-builder --win",
    "clean": "rimraf out release",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.6.3",
    "@monaco-editor/react": "^4.7.0",
    "@netior/narre-server": "workspace:*",
    "@netior/service": "workspace:*",
    "@netior/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/agents-core": "0.8.3",
    "@openai/agents-openai": "0.8.3",
    "@openai/agents-realtime": "0.8.3",
    "@uiw/react-codemirror": "^4.25.9",
    "bindings": "^1.5.0",
    "codemirror-markdown-hybrid": "^1.2.2",
    "debug": "^4.4.0",
    "file-uri-to-path": "^1.0.0",
    "node-pty": "^1.1.0",
    "openai": "^6.26.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "remark-gfm": "^4.0.1",
    "xterm": "5.3.0",
    "xterm-addon-canvas": "0.5.0",
    "xterm-addon-fit": "0.8.0",
    "xterm-addon-search": "0.13.0",
    "xterm-addon-unicode11": "0.6.0",
    "xterm-addon-webgl": "0.16.0",
    "vscode-icons-js": "^11.6.1",
    "ws": "^8.18.1",
    "zod": "^4.3.6",
    "zustand": "^4.4.7"
  },
  "build": {
    "appId": "com.netior.app",
    "productName": "Netior",
    "icon": "build/icons/netior-app-icon.png",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "package.json",
      "out/**/*",
      "node_modules/node-pty/package.json",
      "node_modules/node-pty/LICENSE",
      "node_modules/node-pty/lib/**/*",
      "node_modules/node-pty/build/Release/*.node",
      "node_modules/node-pty/build/Release/*.dll",
      "node_modules/node-pty/build/Release/*.exe"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/node-runtime",
        "to": "node-runtime",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/packaged-sidecars",
        "to": "sidecars",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "build/icons/netior-app-icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh",
      "installerIcon": "build/icons/netior-app-icon.ico",
      "uninstallerIcon": "build/icons/netior-app-icon.ico"
    }
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@electron/rebuild": "^4.0.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "jsdom": "^29.0.1",
    "lucide-react": "^0.563.0",
    "postcss": "^8.4.33",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^2.1.9"
  }
}
